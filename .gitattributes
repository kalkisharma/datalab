# Release integrity (found at first publish, v2.3.0): the built artifact is
# published byte-for-byte with its SHA-256 — git must never normalize its
# line endings, or the committed blob (= release asset) hashes differently
# from the build output that printed the hash.
datalab.html -text

# Bundled libraries are hash-pinned in docs/DEPENDENCIES.md and verified by
# build.js against the working tree — eol conversion on a fresh clone would
# abort every build.
lib/*.js -text

# Shell scripts must stay LF — a CRLF shebang line breaks execution.
*.sh text eol=lf
